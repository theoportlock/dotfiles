! --- Bell / Audio Settings ---
! Enabling visualBell redirects the audio "beep" to a silent screen flash.
XTerm*visualBell: true
XTerm*bellIsUrgent: false
XTerm*bellSuppressTime: 100
XTerm*bellVolume: 0
XTerm*marginBell: false

! --- Look and Feel ---
*faceName: Ubuntu mono
*faceSize: 10
*font: -misc-fixed-medium-r-normal--20-200-75-75-c-100-iso8859-1
*foreground: rgb:a8/a8/a8
*background: rgb:00/00/00

! --- Terminal Behavior ---
*loginShell: true
*savelines: 50000
*jumpScroll: true
*scrollTtyOutput: false
*scrollKey: true
*trimSelection: true
*highlightSelection: true
*alwaysUseMods: true
*metaSendsEscape: true
*utf8Title: true
*selectToClipboard: true
*printFileImmediate: /tmp/

! --- Character Classes ---
*charClass: 33:48,36-47:48,58-59:48,61:48,63-64:48,95:48,126:48

! --- Colors ---
*color0:     rgb:00/00/00
*color1:     rgb:CC/00/00
*color2:     rgb:00/88/00
*color3:     rgb:96/8a/38
*color4:     rgb:41/41/71
*color5:     rgb:96/3c/59
*color6:     rgb:41/81/79
*color7:     rgb:be/be/be
*color8:     rgb:66/66/66
*color9:     rgb:cf/61/71
*color10:    rgb:7c/bc/8c
*color11:    rgb:ff/f7/96
*color12:    rgb:41/86/be
*color13:    rgb:cf/9e/be
*color14:    rgb:71/be/be
*color15:    rgb:ff/ff/ff

! --- Keybindings and Interactions ---
*.vt100.locale: true
*.vt100*translations: #override \n\
  Ctrl <Key> minus: smaller-vt-font() \n\
  Ctrl <Key> plus: larger-vt-font() \n\
  Ctrl <Key> 0: set-vt-font(d) \n\
  Ctrl Shift <Key> C: copy-selection(CLIPBOARD) \n\
  Ctrl Shift <Key> V: insert-selection(CLIPBOARD) \n\
  Shift <Btn1Up>: exec-formatted("xdg-open '%t'", PRIMARY) \n\
  <Btn1Up>: select-end(PRIMARY, CLIPBOARD, CUT_BUFFER0) \n\
  <Btn2Up>: insert-selection(PRIMARY) \n\
  Ctrl Shift <Key> y: print-immediate()
